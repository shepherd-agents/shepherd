[project]
name = "shepherd-{{name}}"
version = "0.1.0a1"
description = "{{description}}"
license = { text = "MIT" }
requires-python = ">=3.10"
authors = [{ name = "Shepherd Team" }]
keywords = {{keywords}}
classifiers = [
    "Development Status :: 3 - Alpha",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Topic :: Scientific/Engineering :: Artificial Intelligence",
]
dependencies = [
    "shepherd-core",
]

[project.optional-dependencies]
dev = ["pytest>=8.0", "pytest-asyncio>=0.23"]

[project.entry-points."shepherd.packages"]
{{name}} = "shepherd_{{module_name}}"

[dependency-groups]
test = ["pytest>=8.0.0,<9.0.0", "pytest-asyncio>=0.23.0,<1.0.0", "pytest-socket>=0.7.0,<1.0.0"]
lint = ["ruff>=0.5.0,<1.0.0"]
typing = ["mypy>=1.10.0,<2.0.0"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/shepherd_{{module_name}}"]

[tool.pytest.ini_options]
addopts = "--strict-markers --strict-config -vv"
asyncio_mode = "auto"
asyncio_default_fixture_loop_scope = "function"
testpaths = ["tests"]

[tool.mypy]
plugins = ["pydantic.mypy"]
strict = true
